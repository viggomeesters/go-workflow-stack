{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "go-workflow.repo-local.hierarchy.v1",
  "title": "Repo-local Go Hierarchy",
  "type": "object",
  "required": [
    "schema",
    "kind",
    "project"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "go-workflow.repo-local.hierarchy.v1"
    },
    "kind": {
      "const": "hierarchy"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "epics": {
      "$ref": "#/$defs/epics"
    },
    "feature_groups": {
      "$ref": "#/$defs/epics",
      "deprecated": true
    }
  },
  "anyOf": [
    { "required": ["epics"] },
    { "required": ["feature_groups"] }
  ],
  "$defs": {
    "epics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "features": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "title"
              ],
              "additionalProperties": true,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "tasks": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
