{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "go-workflow.repo-local.event.v1",
  "title": "Repo-local Go JSONL Event",
  "type": "object",
  "required": [
    "schema",
    "kind",
    "event",
    "created_at",
    "task_id"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "go-workflow.repo-local.event.v1"
    },
    "kind": {
      "const": "event"
    },
    "event": {
      "enum": [
        "task.claimed",
        "task.finished",
        "evidence.appended",
        "decision.recorded",
        "run.checked"
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "agent": {
      "type": "string"
    },
    "data": {
      "type": "object"
    }
  }
}
