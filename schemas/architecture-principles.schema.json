{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "go-workflow.repo-local.architecture-principles.v1",
  "title": "Repo-local Go Architecture Principles",
  "type": "object",
  "required": [
    "schema",
    "kind",
    "project",
    "principles"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "go-workflow.repo-local.architecture-principles.v1"
    },
    "kind": {
      "const": "architecture_principles"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "principles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "statement",
          "rationale",
          "enforcement"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "enforcement": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
